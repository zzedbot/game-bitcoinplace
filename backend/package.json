{
  "name": "bitcoinplace-backend",
  "version": "1.0.0",
  "description": "BitcoinPlace Game Backend - Node.js + Fastify + TypeScript",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsup src/index.ts --watch --onSuccess \"node dist/index.js\"",
    "build": "tsup src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "keywords": [
    "bitcoinplace",
    "game",
    "blockchain",
    "fastify"
  ],
  "author": "ZedBot",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@prisma/client": "^5.10.0",
    "@types/bcrypt": "^6.0.0",
    "@types/ws": "^8.18.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.0",
    "fastify": "^4.26.0",
    "ioredis": "^5.10.1",
    "nodemailer": "^8.0.4",
    "prisma": "^5.10.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.6.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
